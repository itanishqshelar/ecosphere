# ─────────────────────────────────────────────────────────────
# ENVIRONMENT TEMPLATE — safe to commit (contains NO real secrets)
#
# Setup:
#   cp .env.example .env.local
# then fill in the values from your Supabase dashboard:
#   Project Settings → API
# ─────────────────────────────────────────────────────────────

# Supabase project URL (safe to expose — sent to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose — protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service-role key (SERVER-ONLY / SECRET — bypasses RLS).
# Never prefix with NEXT_PUBLIC_. Used only by scripts/seed.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL used to build auth redirect links.
# In production set this to your deployed origin (e.g. https://app.example.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables receipt image analysis for carbon transaction autofill.
GROQ_API_KEY=your-groq-api-key

# Public bucket used by the challenge proof upload workflow.
NEXT_PUBLIC_CHALLENGE_PROOF_BUCKET=challenge-proofs
